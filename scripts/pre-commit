#!/bin/sh
# pre-commit hook — blocks accidental commit of sensitive files
# Installed by: Task #001 — Environment Audit & Security Baseline
# Project: GoldInvestmentApp (Catat Emas)
#
# INSTALLATION:
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit  # on macOS/Linux
#
# Windows (Git for Windows / PowerShell):
#   Copy-Item scripts/pre-commit .git/hooks/pre-commit

# List of patterns that must never be committed
BLOCKED_PATTERNS="
\.env$
\.env\.local$
\.env\.production$
\.env\.staging$
.*\.keystore$
.*\.jks$
.*\.p12$
.*\.pem$
.*\.key$
"

STAGED_FILES=$(git diff --cached --name-only)

FOUND_VIOLATION=0
for pattern in $BLOCKED_PATTERNS; do
  # Skip empty lines
  [ -z "$pattern" ] && continue

  MATCH=$(echo "$STAGED_FILES" | grep -E "$pattern" | grep -v "\.example$" | grep -v "debug\.keystore")
  if [ -n "$MATCH" ]; then
    echo "🚫 BLOCKED: Attempted commit of sensitive file(s):"
    echo "$MATCH" | while read -r f; do
      echo "   - $f"
    done
    FOUND_VIOLATION=1
  fi
done

if [ "$FOUND_VIOLATION" -eq 1 ]; then
  echo ""
  echo "These files must NOT be committed to the repository."
  echo "Use .env.example for template; store real values in .env (gitignored)."
  echo "If this is intentional (e.g., debug.keystore), use: git commit --no-verify"
  exit 1
fi

exit 0
